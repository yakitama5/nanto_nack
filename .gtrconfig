# .gtrconfig - commit this file to share settings with your team

[copy]
    include = **/.env
    include = **/.env**
    include = **/firebase_options**.dart
    include = **/google-services.json

[hooks]
    postCreate = fvm use
    postCreate = fvm flutter pub get
    postCreate = fvm dart run melos bs
    postCreate = fvm dart run melos run generate

[defaults]
    editor = zed
    ai = claude
